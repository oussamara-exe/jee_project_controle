<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Application de Gestion RH Avancée</display-name>
    <description>Système de gestion des ressources humaines avec JEE</description>

    <!-- Page d'accueil -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- Configuration du timeout de session (30 minutes) -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <secure>false</secure> <!-- Mettre à true en production avec HTTPS -->
            <name>JSESSIONID</name>
            <path>/gestion-rh</path>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- Pages d'erreur personnalisées -->
    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/pages/errors/403.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/pages/errors/404.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/pages/errors/500.jsp</location>
    </error-page>

    <!-- Configuration JSTL -->
    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <page-encoding>UTF-8</page-encoding>
            <include-prelude>/WEB-INF/fragments/taglibs.jsp</include-prelude>
        </jsp-property-group>
    </jsp-config>

    <!-- Encodage UTF-8 pour toutes les requêtes -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>ma.projet.rh.filters.CharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
        <dispatcher>FORWARD</dispatcher>
    </filter-mapping>

    <!-- Filtre de sécurité / authentification -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>ma.projet.rh.filters.AuthenticationFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/app/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
    </filter-mapping>

    <!-- Filtre d'autorisation (vérification des rôles) -->
    <filter>
        <filter-name>AuthorizationFilter</filter-name>
        <filter-class>ma.projet.rh.filters.AuthorizationFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/app/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
    </filter-mapping>

    <!-- Filtre de logging des actions -->
    <filter>
        <filter-name>AuditFilter</filter-name>
        <filter-class>ma.projet.rh.filters.AuditFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>AuditFilter</filter-name>
        <url-pattern>/app/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
    </filter-mapping>

    <!-- Protection CSRF -->
    <filter>
        <filter-name>CsrfFilter</filter-name>
        <filter-class>ma.projet.rh.filters.CsrfFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/app/*</url-pattern>
    </filter-mapping>

    <!-- Configuration de sécurité JAAS DÉSACTIVÉE -->
    <!-- Nous utilisons nos propres filtres d'authentification au lieu de JAAS -->
    <!-- 
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Pages protégées</web-resource-name>
            <url-pattern>/app/*</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <role-name>EMPLOYE</role-name>
            <role-name>MANAGER</role-name>
            <role-name>RH</role-name>
            <role-name>ADMIN</role-name>
        </auth-constraint>
    </security-constraint>
    -->

    <!-- Paramètres de contexte -->
    <context-param>
        <param-name>javax.faces.PROJECT_STAGE</param-name>
        <param-value>Development</param-value>
    </context-param>
    
    <context-param>
        <param-name>javax.faces.FACELETS_SKIP_COMMENTS</param-name>
        <param-value>true</param-value>
    </context-param>

    <!-- Référence à la datasource -->
    <resource-ref>
        <res-ref-name>jdbc/GestionRHDS</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>
    
    <!-- Déclaration des servlets -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.DashboardServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/app/dashboard</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>EmployeServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.EmployeServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>EmployeServlet</servlet-name>
        <url-pattern>/app/employes/*</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>CongeServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.CongeServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>CongeServlet</servlet-name>
        <url-pattern>/app/conges/*</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>DepartementServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.DepartementServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>DepartementServlet</servlet-name>
        <url-pattern>/app/departements/*</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>PosteServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.PosteServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>PosteServlet</servlet-name>
        <url-pattern>/app/postes/*</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>TempsServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.TempsServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>TempsServlet</servlet-name>
        <url-pattern>/app/temps/*</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>PaieServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.PaieServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>PaieServlet</servlet-name>
        <url-pattern>/app/paie/*</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>RapportServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.RapportServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>RapportServlet</servlet-name>
        <url-pattern>/app/rapports/*</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.AdminServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/app/admin/*</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.LogoutServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>NotificationServlet</servlet-name>
        <servlet-class>ma.projet.rh.servlets.NotificationServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>NotificationServlet</servlet-name>
        <url-pattern>/app/notifications</url-pattern>
    </servlet-mapping>
</web-app>

